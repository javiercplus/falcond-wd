# Template file for 'falcond-wd'
pkgname=falcond-wd
version=2.0.8
revision=6
build_wrksrc="falcond"
hostmakedepends="git zig"
depends="dbus sudo power-profiles-daemon scx"
short_desc="Advanced Linux Gaming Performance Daemon"
maintainer="JavierC"
license="MIT"
homepage="https://github.com/PikaOS-Linux/falcond"
distfiles="https://github.com/javiercplus/falcond-wd/archive/refs/tags/${version}.tar.gz"
checksum=a3f6051d3b18dfd4cc6f0b8b078375ca3a7f2efd7284ab1bca13d0b03bf28f25

post_extract() {
    # Clonar perfiles y dependencias manualmente
    git clone --depth 1 https://github.com/PikaOS-Linux/falcond-profiles.git ${wrksrc}/falcond/profiles
    git clone --depth 1 --branch v0.10.31 https://git.pika-os.com/otter-shell/otter-conf ${wrksrc}/otter-conf
    git clone --depth 1 --branch v0.10.31 https://git.pika-os.com/otter-shell/otter-desktop ${wrksrc}/otter-desktop
    git clone --depth 1 --branch v0.10.31 https://git.pika-os.com/otter-shell/otter-utils ${wrksrc}/otter-utils

    # Arreglar el error del literal de cadena en todos los proyectos
    sed -i 's/\.name = \.falcond,/.name = "falcond",/' ${wrksrc}/falcond/build.zig.zon
    sed -i 's/\.name = \.otter_conf,/.name = "otter_conf",/' ${wrksrc}/otter-conf/build.zig.zon
    sed -i 's/\.name = \.otter_desktop,/.name = "otter_desktop",/' ${wrksrc}/otter-desktop/build.zig.zon
    sed -i 's/\.name = \.otter_utils,/.name = "otter_utils",/' ${wrksrc}/otter-utils/build.zig.zon

    # Eliminar las líneas de hash inválidas
    sed -i '/\.hash =/d' ${wrksrc}/falcond/build.zig.zon

    # Reemplazar las URLs de descarga por rutas locales
    sed -i 's|\.url = ".*otter-conf.*"|.path = "../otter-conf",|' ${wrksrc}/falcond/build.zig.zon
    sed -i 's|\.url = ".*otter-desktop.*"|.path = "../otter-desktop",|' ${wrksrc}/falcond/build.zig.zon
    sed -i 's|\.url = ".*otter-utils.*"|.path = "../otter-utils",|' ${wrksrc}/falcond/build.zig.zon
}
do_build() {
    zig build -Doptimize=ReleaseFast -Dcpu=x86_64_v3
}

do_install() {
    vbin zig-out/bin/falcond
    
    if [ -f ${wrksrc}/LICENSE ]; then
        vlicense ${wrksrc}/LICENSE
    fi
    
    vmkdir usr/share/falcond
    if [ -d profiles/usr/share/falcond ]; then
        cp -r profiles/usr/share/falcond/* ${DESTDIR}/usr/share/falcond/
    fi
    
    vmkdir var/lib/falcond
}
