# Template file for 'falcond-wd'
pkgname=falcond-wd
version=2.0.8
revision=9
archs="x86_64*"
build_style=none
hostmakedepends="zig-nk git"
depends="dbus scx"
short_desc="Advanced Linux Gaming Performance Daemon"
maintainer="JavierC"
license="MIT"
homepage="https://github.com/PikaOS-Linux/falcond"
distfiles="https://github.com/javiercplus/falcond-wd/releases/download/2.0.8/falcond-wd-main.tar.gz"
checksum=7a39e9c0741a6167b11cc392f7318f45d8b24bdae39a7d552ee1b2fbfceb43ef
nopie=yes

post_extract() {
    # post_extract se ejecuta en ${wrksrc} = falcond-wd-2.0.8/

    # Clonar perfiles dentro de la subcarpeta falcond/
    git clone --depth 1 https://github.com/PikaOS-Linux/falcond-profiles.git falcond/profiles

}

do_build() {
    # El build.zig está en falcond/, no en la raíz del tarball
    cd falcond
    zig build -Doptimize=ReleaseFast -Dcpu=baseline
}

do_install() {
    cd falcond

    # Instalar binario
    vbin zig-out/bin/falcond

    # Instalar perfiles
    vmkdir usr/share/falcond
    cp -r profiles/usr/share/falcond/* ${DESTDIR}/usr/share/falcond/

    # Instalar servicio runit
    vmkdir etc/sv/falcond
    cat << 'EOF' > ${DESTDIR}/etc/sv/falcond/run
#!/bin/sh
exec falcond
EOF
    chmod 755 ${DESTDIR}/etc/sv/falcond/run

    # Directorio de estado
    vmkdir var/lib/falcond

    # Licencia (está en la raíz del repo, un nivel arriba)
    [ -f ../LICENSE ] && vlicense ../LICENSE
}
